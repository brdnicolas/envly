{
  "name": "Envly - Shared Wishlists",
  "short_name": "Envly",
  "description": "Create and share wishlists with anonymous reservations. Friends and family can reserve gifts without spoiling the surprise.",
  "categories": ["lifestyle", "shopping", "social"],
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/add",
    "method": "GET",
    "params": {
      "url": "url",
      "title": "title",
      "text": "text"
    }
  }
}
